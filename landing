<script>
  // Countdown timer
  (function() {
    var h = 23, m = 59, s = 59;
    function tick() {
      s--;
      if (s < 0) { s = 59; m--; }
      if (m < 0) { m = 59; h--; }
      if (h < 0) { h = 23; m = 59; s = 59; }
      document.getElementById('h').textContent = String(h).padStart(2,'0');
      document.getElementById('m').textContent = String(m).padStart(2,'0');
      document.getElementById('s').textContent = String(s).padStart(2,'0');
    }
    setInterval(tick, 1000);
  })();

  // Form submit
  function handleSubmit(e) {
    e.preventDefault();
    var name = document.getElementById('fname').value;
    document.getElementById('fname-confirm').textContent = name;
    document.getElementById('form-area').style.display = 'none';
    document.getElementById('success-msg').style.display = 'block';
  }

  // Smooth nav highlight
  var sections = document.querySelectorAll('section[id], div[id="offer"]');
  var navLinks = document.querySelectorAll('.nav-links a');
  window.addEventListener('scroll', function() {
    var scrollY = window.pageYOffset;
    sections.forEach(function(s) {
      if (s.offsetTop - 100 <= scrollY && s.offsetTop + s.offsetHeight > scrollY) {
        navLinks.forEach(function(l) {
          l.style.color = l.getAttribute('href') === '#' + s.id ? '#1a5cff' : '';
        });
      }
    });
  });
</script>
